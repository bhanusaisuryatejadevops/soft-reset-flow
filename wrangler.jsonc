{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "resetflow",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/server/index.mjs",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS"
  },
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": ["**/*.mjs", "**/*.js"]
    }
  ]
}
